---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardHeader, CardTitle, CardContent, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout title="Projects" description="Open source projects, demo apps, video series, and experiments.">
  <section class="pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="container mx-auto px-6">
      <span class="text-xs font-mono text-muted-foreground tracking-wider">Projects</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-8 mb-4 tracking-tight">Things I've built</h1>
      <p class="text-lg text-muted-foreground mb-16 max-w-screen-md">
        A mix of developer tools, demo applications, video series, and side experiments.
        Check out my <a href="https://github.com/antonarhipov/" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GitHub</a> for even more things I've built.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <div class="group block h-full">
            <Card className="h-full transition-colors group-hover:border-primary/50 flex flex-col">
              <CardHeader>
                <div class="mb-4">
                  <Badge variant="outline" className="font-mono text-[10px] tracking-wider uppercase-none">{project.data.category}</Badge>
                </div>
                <CardTitle className="transition-colors text-xl">
                  <a href={`/projects/${project.id}`} class="group-hover:text-primary transition-colors">
                    {project.data.title}
                  </a>
                </CardTitle>
                <CardDescription className="flex-1">{project.data.description}</CardDescription>
              </CardHeader>
              <CardContent className="mt-auto">
                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {project.data.tags.map(tag => (
                    <span class="text-[10px] font-mono text-muted-foreground">#{tag}</span>
                  ))}
                </div>

                <div class="flex flex-wrap gap-2 mt-4">
                  <Button variant="outline" size="sm" asChild>
                    <a href={`/projects/${project.id}`}>Details →</a>
                  </Button>
                </div>
              </CardContent>
            </Card>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
