---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card, CardHeader, CardTitle, CardContent, CardDescription } from '@/components/ui/card';
import { getCollection } from 'astro:content';
import { compareTalks } from '@/lib/talks';

const talks = (await getCollection('talks'))
  .filter(talk => !talk.data.draft)
  .sort(compareTalks);
---

<BaseLayout title="Talks" description="Conference presentations on debugging, Spring Boot, IDE productivity, and AI-assisted development.">
  <section class="pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="container mx-auto px-6">
      <span class="text-xs font-mono text-muted-foreground tracking-wider">Talks</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-8 mb-4 tracking-tight">Speaking</h1>
      <p class="text-lg text-muted-foreground mb-16 max-w-screen-md">
        Conference talks and live-coding sessions about debugging, persistence
        patterns, IDE workflows, and AI-augmented development.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {talks.map((talk) => (
          <a href={`/talks/${talk.id}`} class="group block h-full">
            <Card className="h-full transition-colors group-hover:border-primary/50 flex flex-col">
              <CardHeader>
                <CardTitle className="group-hover:text-primary transition-colors text-xl">{talk.data.title}</CardTitle>
                <CardDescription className="flex-1">{talk.data.summary}</CardDescription>
              </CardHeader>
              <CardContent className="mt-auto">
                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {talk.data.tags.map(tag => (
                    <span class="text-[10px] font-mono text-muted-foreground">#{tag}</span>
                  ))}
                </div>
              </CardContent>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
