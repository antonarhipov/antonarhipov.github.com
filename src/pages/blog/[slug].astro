---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { Badge } from '@/components/ui/badge';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog'))
    .filter((post) => !post.data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="container mx-auto px-6 max-w-[65ch]">
      <Breadcrumbs title={post.data.title} />
      
      <header class="mb-12">
        <time class="text-xs font-mono text-muted-foreground" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </time>
        <h1 class="text-3xl md:text-4xl font-bold mt-4 mb-6 tracking-tight text-foreground">{post.data.title}</h1>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => <Badge variant="secondary">{tag}</Badge>)}
        </div>
      </header>

      <div class="prose prose-zinc dark:prose-invert max-w-none prose-headings:text-foreground prose-a:text-primary prose-a:underline-offset-4 hover:prose-a:text-primary/80 transition-colors prose-pre:bg-muted prose-pre:border prose-pre:border-border">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
