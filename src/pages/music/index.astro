---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Music" description="DAWless electronic synth music with the Korg MS-20 mini, Arturia DrumBrute Impact, Minilogue XD, and Zoom MS-70CDR — pure hardware sound design.">
  <section class="pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="container mx-auto px-6">
      <span class="text-xs font-mono text-muted-foreground tracking-wider">Music</span>
      <h1 class="text-4xl md:text-5xl font-bold mt-8 mb-4 tracking-tight">Electronic Synth Music</h1>
      <p class="text-lg text-muted-foreground mb-16 max-w-screen-md">
        Beyond code, I explore the world of analog sound — fully DAWless, no computer
        involved in the performance. My setup revolves around the Korg MS-20 mini paired with
        a Zoom MS-70CDR for lush effects, the Arturia DrumBrute Impact for raw analog beats,
        and the Minilogue XD for rich polyphonic textures. There's something deeply satisfying
        about patching cables, tweaking knobs, and shaping raw waveforms into something alive
        — all happening in real time on hardware alone.
      </p>

      <div class="mb-16">
        <div class="aspect-video max-w-2xl">
          <iframe
            width="100%"
            height="100%"
            src="https://www.youtube.com/embed/-U7FPtXec3Q?si=OwXqdsotVQXouKCn"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
            class="rounded-lg border border-border"
          ></iframe>
        </div>
      </div>

      <div class="mb-4 max-w-2xl">
        <iframe width="100%" height="166" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%253Atracks%253A1629371553&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"></iframe><div style="font-size: 10px; color: #cccccc;line-break: anywhere;word-break: normal;overflow: hidden;white-space: nowrap;text-overflow: ellipsis; font-family: Interstate,Lucida Grande,Lucida Sans Unicode,Lucida Sans,Garuda,Verdana,Tahoma,sans-serif;font-weight: 100;"><a href="https://soundcloud.com/anton-arhipov-tln" title="Anton Arhipov" target="_blank" style="color: #cccccc; text-decoration: none;">Anton Arhipov</a> · <a href="https://soundcloud.com/anton-arhipov-tln/robots-hang-out-on-saturdays" title="Robots Hang Out On Saturdays" target="_blank" style="color: #cccccc; text-decoration: none;">Robots Hang Out On Saturdays</a></div>
      </div>

      <div class="mb-4 max-w-2xl">
        <iframe width="100%" height="166" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%253Atracks%253A1648037184&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"></iframe><div style="font-size: 10px; color: #cccccc;line-break: anywhere;word-break: normal;overflow: hidden;white-space: nowrap;text-overflow: ellipsis; font-family: Interstate,Lucida Grande,Lucida Sans Unicode,Lucida Sans,Garuda,Verdana,Tahoma,sans-serif;font-weight: 100;"><a href="https://soundcloud.com/anton-arhipov-tln" title="Anton Arhipov" target="_blank" style="color: #cccccc; text-decoration: none;">Anton Arhipov</a> · <a href="https://soundcloud.com/anton-arhipov-tln/binary-dreamscape" title="Binary Dreamscape" target="_blank" style="color: #cccccc; text-decoration: none;">Binary Dreamscape</a></div>
      </div>

      <div class="mb-4 max-w-2xl">
        <iframe width="100%" height="166" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%253Atracks%253A1652435223&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true"></iframe><div style="font-size: 10px; color: #cccccc;line-break: anywhere;word-break: normal;overflow: hidden;white-space: nowrap;text-overflow: ellipsis; font-family: Interstate,Lucida Grande,Lucida Sans Unicode,Lucida Sans,Garuda,Verdana,Tahoma,sans-serif;font-weight: 100;"><a href="https://soundcloud.com/anton-arhipov-tln" title="Anton Arhipov" target="_blank" style="color: #cccccc; text-decoration: none;">Anton Arhipov</a> · <a href="https://soundcloud.com/anton-arhipov-tln/roborythmic-jam" title="RoboRythmic Jam" target="_blank" style="color: #cccccc; text-decoration: none;">RoboRythmic Jam</a></div>
      </div>

      <div class="mb-16">
        <h2 class="text-2xl font-bold mb-6 tracking-tight">Gear</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-screen-md">
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Korg MS-20 mini</span>
          </li>
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Minilogue XD module</span>
          </li>
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Korg Volca Nubass</span>
          </li>
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Arturia DrumBrute Impact</span>
          </li>
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Zoom MS-70CDR effects pedal</span>
          </li>
          <li class="flex items-center gap-3 rounded-lg border border-border p-4">
            <span class="text-primary text-lg">▸</span>
            <span class="text-sm font-medium">Arturia Keystep Pro MIDI controller</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
